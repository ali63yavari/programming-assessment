# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Go build output
/bin/
/dist/
/build/

# Common per-project build output
src/*/bin/
src/*/dist/
src/*/build/

# Go coverage files
*.out
coverage.out
coverage.html

# Go profiling files
*.prof
*.pprof

# Go workspace file
# Commit go.work only if the whole repository is intentionally managed
# as a single Go workspace.
go.work
go.work.sum


